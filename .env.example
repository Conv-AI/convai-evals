PORT=4000
TTS_CACHE_DIR=./cache/tts

# The Convai prod endpoint URL is entered at runtime — in the web form, or via the
# ENDPOINT_URL env var for the headless runner (scripts/run-batch.mjs). It is not stored here.

CONVAI_EVALS_TTS_API_KEY=
CONVAI_EVALS_JUDGE_API_KEY=

DIAG_PROVIDER=none
CONVAI_ANALYTICS_BASE_URL=https://analytics-api.convai.com/v1/analytics
CONVAI_API_KEY=
DIAG_ROW_CONCURRENCY=4
DIAG_FETCH_SUCCESSFUL_ROWS=false
